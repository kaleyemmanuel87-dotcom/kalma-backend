const express = require('express');
const router = express.Router();
const pool = require('../db');
const auth = require('../middleware/auth');

// 1. RECHERCHE GLOBALE (Utilisateurs et Hashtags) - Pour la loupe de recherche
router.get('/search', auth, async (req, res) => {
    const { q } = req.query; // Le texte tapé dans la barre de recherche ex: ?q=ema
    if (!q || q.trim() === "") return res.json({ users: [], hashtags: [] });

    try {
        const searchTerm = `%${q.trim()}%`;

        // Rechercher des utilisateurs par leur pseudo
        const usersSearch = await pool.query(
            'SELECT id, username, avatar_url FROM users WHERE username ILIKE $1 LIMIT 10',
            [searchTerm]
        );

        // Rechercher des hashtags (en enlevant le # s'il a été tapé)
        const cleanTag = q.replace('#', '');
        const hashtagsSearch = await pool.query(
            'SELECT id, name FROM hashtags WHERE name ILIKE $1 LIMIT 10',
            [`%${cleanTag}%`]
        );

        res.json({
            users: usersSearch.rows,
            hashtags: hashtagsSearch.rows
        });
    } catch (err) {
        console.error(err.message);
        res.status(500).send("Erreur lors de la recherche");
    }
});

// 2. RÉCUPÉRER LES POSTS ASSOCIÉS À UN HASHTAG SPÉCIFIQUE
router.get('/hashtag/:tagName', auth, async (req, res) => {
    const { tagName } = req.params;

    try {
        const posts = await pool.query(
            `SELECT p.*, u.username, u.avatar_url 
             FROM posts p
             JOIN users u ON p.user_id = u.id
             JOIN post_hashtags ph ON p.id = ph.post_id
             JOIN hashtags h ON ph.hashtag_id = h.id
             WHERE h.name = $1
             ORDER BY p.created_at DESC`,
            [tagName.toLowerCase().trim()]
        );
        res.json(posts.rows);
    } catch (err) {
        console.error(err.message);
        res.status(500).send("Erreur serveur lors de la récupération du hashtag");
    }
});

module.exports = router;